---
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryCard from "../components/GalleryCard.astro";
import { getCollection } from "astro:content";

const galleries = await getCollection("galleries");
galleries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout title="Your Name — Photography" description="Photography portfolio showcasing landscapes, street, and more.">
  <section class="relative h-[80vh] flex items-center justify-center">
    <div class="absolute inset-0 bg-gradient-to-b from-stone-900 to-stone-950"></div>
    <div class="relative z-10 text-center px-6">
      <h1 class="font-['Playfair_Display'] text-5xl md:text-7xl font-medium text-white mb-4">
        Your Name
      </h1>
      <p class="text-lg text-stone-400 max-w-xl mx-auto">
        Photographer · Cyclist · Observer of light
      </p>
      
       <a href="/gallery" class="inline-block mt-8 px-6 py-3 border border-stone-600 text-sm text-stone-300 hover:bg-white hover:text-stone-950 transition-all duration-300">
        View Galleries
      </a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-20">
    <h2 class="font-['Playfair_Display'] text-2xl text-white mb-10">Featured Work</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {galleries.map((gallery) => (
        <GalleryCard
          title={gallery.data.title}
          description={gallery.data.description}
          coverImage={gallery.data.coverImage}
          slug={gallery.id}
          photoCount={gallery.data.photos.length}
        />
      ))}
    </div>
  </section>
</BaseLayout>