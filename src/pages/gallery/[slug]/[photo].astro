---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const galleries = await getCollection("galleries");
  const paths = [];

  for (const gallery of galleries) {
    gallery.data.photos.forEach((photo, index) => {
      paths.push({
        params: {
          slug: gallery.id,
          photo: String(index),
        },
        props: {
          gallery,
          photo,
          index,
          total: gallery.data.photos.length,
        },
      });
    });
  }

  return paths;
}

const { gallery, photo, index, total } = Astro.props;
const galleryId = gallery.id;
const galleryTitle = gallery.data.title;

const prevIndex = index > 0 ? index - 1 : null;
const nextIndex = index < total - 1 ? index + 1 : null;

const exifData = {
  camera: "—",
  lens: "—",
  aperture: "—",
  shutter: "—",
  iso: "—",
  date: "—",
};
---

<BaseLayout
  title={photo.alt + " — " + galleryTitle}
  description={photo.caption || photo.alt}
>
  <section class="max-w-6xl mx-auto px-6 py-12">

    <div class="flex items-center justify-between mb-8">
      
        <a href={"/gallery/" + galleryId}
        class="text-sm text-stone-400 hover:text-white transition-colors"
      >
        ← {galleryTitle}
      </a>
      <span class="text-sm text-stone-500">
        {index + 1} / {total}
      </span>
    </div>

    <div class="bg-stone-900 flex items-center justify-center">
      <img
        src={photo.src}
        alt={photo.alt}
        class="max-h-[75vh] w-auto object-contain"
      />
    </div>

    <div class="mt-8 flex flex-col md:flex-row md:items-start md:justify-between gap-8">

      <div class="flex-1">
        {photo.caption && (
          <p class="text-stone-300 text-lg mb-2">{photo.caption}</p>
        )}
        <p class="text-stone-400 text-sm">{photo.alt}</p>
      </div>

      <div class="grid grid-cols-3 gap-x-8 gap-y-3 text-sm shrink-0">
        <div>
          <p class="text-stone-500 text-xs uppercase tracking-wider">Camera</p>
          <p class="text-stone-400">{exifData.camera}</p>
        </div>
        <div>
          <p class="text-stone-500 text-xs uppercase tracking-wider">Lens</p>
          <p class="text-stone-400">{exifData.lens}</p>
        </div>
        <div>
          <p class="text-stone-500 text-xs uppercase tracking-wider">Aperture</p>
          <p class="text-stone-400">{exifData.aperture}</p>
        </div>
        <div>
          <p class="text-stone-500 text-xs uppercase tracking-wider">Shutter</p>
          <p class="text-stone-400">{exifData.shutter}</p>
        </div>
        <div>
          <p class="text-stone-500 text-xs uppercase tracking-wider">ISO</p>
          <p class="text-stone-400">{exifData.iso}</p>
        </div>
        <div>
          <p class="text-stone-500 text-xs uppercase tracking-wider">Date</p>
          <p class="text-stone-400">{exifData.date}</p>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between mt-12 pt-8 border-t border-stone-800/50">
      {prevIndex !== null ? (
        
          <a href={"/gallery/" + galleryId + "/" + prevIndex}
          class="text-sm text-stone-400 hover:text-white transition-colors"
        >
          ← Previous
        </a>
      ) : (
        <span></span>
      )}
      {nextIndex !== null ? (
        
          <a href={"/gallery/" + galleryId + "/" + nextIndex}
          class="text-sm text-stone-400 hover:text-white transition-colors"
        >
          Next →
        </a>
      ) : (
        <span></span>
      )}
    </div>

  </section>
</BaseLayout>