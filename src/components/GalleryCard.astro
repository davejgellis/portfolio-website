---
// GalleryCard.astro
// A clickable card that shows a gallery's cover image, title, and description.
// Used on the gallery overview page and the homepage featured section.

const { title, description, coverImage, slug, photoCount } = Astro.props;
---

<a href={`/gallery/${slug}`} class="group block">
  <div class="relative aspect-4/3 overflow-hidden bg-stone-900">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <!-- Dark overlay that lightens on hover -->
    <div class="absolute inset-0 bg-stone-950/30 group-hover:bg-stone-950/10 transition-colors duration-500"></div>
  </div>
  <div class="mt-4">
    <h3 class="font-['Playfair_Display'] text-lg text-white group-hover:text-stone-300 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-stone-400 mt-1">{description}</p>
    <p class="text-xs text-stone-500 mt-2">{photoCount} photos</p>
  </div>
</a>